# ──────────────────────────────────────────
#  PostgreSQL
# ──────────────────────────────────────────
POSTGRES_USER=dms_user
POSTGRES_PASSWORD=dms_secret_password
POSTGRES_DB=dms_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

DATABASE_URL=postgresql://dms_user:dms_secret_password@db:5432/dms_db

# ──────────────────────────────────────────
#  Backend (FastAPI)
# ──────────────────────────────────────────
SECRET_KEY=change_me_to_a_random_64_char_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# ──────────────────────────────────────────
#  Frontend (Next.js)
# ──────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=DMS — Delivery Management System
